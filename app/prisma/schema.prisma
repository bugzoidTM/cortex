generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  plan         String   @default("beta")
  monthlyQuota Int      @default(1000000)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brandProfile       BrandProfile?
  briefings          Briefing[]
  jobs               SkillJob[]
  artifacts          Artifact[]
  usageLedger        LLMUsageLedger[]
  memberships        TenantMembership[]
  llmProviderConfigs LLMProviderConfig[]
  llmCredential      TenantLlmCredential?
  subscriptions      Subscription[]
  paymentInvoices    PaymentInvoice[]
}

model TenantLlmCredential {
  id              String   @id @default(cuid())
  tenantId        String
  provider        String
  baseUrl         String
  model           String
  encryptedApiKey String
  apiKeyPreview   String
  trialStartedAt  DateTime @default(now())
  trialEndsAt     DateTime
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
  @@index([enabled, trialEndsAt])
}

model LLMProviderConfig {
  id              String   @id @default(cuid())
  tenantId        String?
  name            String   @default("default")
  provider        String
  baseUrl         String
  model           String
  inputCostPer1M  Decimal  @default(0) @db.Decimal(10, 4)
  outputCostPer1M Decimal  @default(0) @db.Decimal(10, 4)
  maxOutputTokens Int      @default(1800)
  timeoutMs       Int      @default(180000)
  enabled         Boolean  @default(true)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usageLedger LLMUsageLedger[]

  @@index([enabled, isDefault])
  @@index([tenantId, enabled, isDefault])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships         TenantMembership[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  emailMessages       EmailMessage[]
}

model TenantMembership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      String   @default("owner")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailMessage {
  id          String    @id @default(cuid())
  userId      String?
  to          String
  subject     String
  text        String
  html        String?
  status      String    @default("PENDING")
  provider    String    @default("smtp")
  error       String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([to, createdAt])
  @@index([status, createdAt])
}

model Subscription {
  id                  String             @id @default(cuid())
  tenantId            String
  plan                String
  status              SubscriptionStatus @default(PENDING)
  amountCents         Int
  currency            String             @default("BRL")
  monthlyQuota        Int
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  pastDueSince        DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices PaymentInvoice[]

  @@index([tenantId, status])
  @@index([status, currentPeriodEnd])
}

model PaymentInvoice {
  id                String        @id @default(cuid())
  tenantId          String
  subscriptionId    String?
  wooviCorrelationID String       @unique
  wooviChargeId     String?
  status            InvoiceStatus @default(PENDING)
  amountCents       Int
  paymentLinkUrl    String?
  brCode            String?
  qrCodeImage       String?
  paidAt            DateTime?
  expiresAt         DateTime?
  rawPayload        Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([status, expiresAt])
}

model BrandProfile {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tone          String
  audience      String
  promise       String
  restrictions  String[] @default([])
  sampleContent String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Briefing {
  id              String   @id @default(cuid())
  tenantId        String
  title           String
  objective       String
  primaryPlatform String
  context         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobs   SkillJob[]
}

model SkillJob {
  id          String    @id @default(cuid())
  tenantId    String
  briefingId  String?
  skill       String
  status      JobStatus @default(PENDING)
  input       Json
  output      Json?
  error       String?
  attempts    Int       @default(0)
  lockedAt    DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  briefing    Briefing?        @relation(fields: [briefingId], references: [id], onDelete: SetNull)
  artifacts   Artifact[]
  usageLedger LLMUsageLedger[]

  @@index([tenantId, createdAt])
  @@index([status])
}

model Artifact {
  id        String   @id @default(cuid())
  tenantId  String
  jobId     String?
  type      String
  title     String
  content   String
  format    String   @default("markdown")
  createdAt DateTime @default(now())

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job    SkillJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
}

model LLMUsageLedger {
  id                  String   @id @default(cuid())
  tenantId            String
  jobId               String?
  provider            String
  model               String
  llmProviderConfigId String?
  inputTokens         Int      @default(0)
  outputTokens        Int      @default(0)
  inputCostPer1M      Decimal  @default(0) @db.Decimal(10, 4)
  outputCostPer1M     Decimal  @default(0) @db.Decimal(10, 4)
  costUsd             Decimal  @default(0) @db.Decimal(10, 6)
  latencyMs           Int      @default(0)
  status              String
  createdAt           DateTime @default(now())

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job               SkillJob?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  llmProviderConfig LLMProviderConfig? @relation(fields: [llmProviderConfigId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([llmProviderConfigId])
}

model RateLimitEvent {
  id        String   @id @default(cuid())
  key       String
  action    String
  createdAt DateTime @default(now())

  @@index([key, action, createdAt])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum InvoiceStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
}
